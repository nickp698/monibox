{
  "name": "monibox-native",
  "version": "1.0.0",
  "private": true,
  "description": "Monibox — Family Finance (Expo Managed, WebView shell)",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "build:ios": "eas build --platform ios --profile production",
